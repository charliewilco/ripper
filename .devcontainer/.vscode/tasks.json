{
	"version": "2.0.0",
	"tasks": [
		{
			"type": "shell",
			"command": "cargo build",
			"problemMatcher": [
				"$rustc"
			],
			"group": {
				"kind": "build",
				"isDefault": true
			},
			"label": "Rust: build project"
		},
		{
			"type": "shell",
			"command": "cargo test",
			"problemMatcher": [
				"$rustc"
			],
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"label": "Rust: run tests"
		},
		{
			"type": "shell",
			"command": "cargo clippy",
			"problemMatcher": [
				"$rustc"
			],
			"label": "Rust: run clippy"
		},
		{
			"type": "shell",
			"command": "cargo fmt",
			"label": "Rust: run formatter"
		},
		{
			"type": "shell",
			"command": "cargo watch -x test",
			"problemMatcher": [
				"$rustc"
			],
			"isBackground": true,
			"label": "Rust: watch tests"
		},
		{
			"type": "shell",
			"command": "just",
			"label": "Just: list available commands"
		}
	]
}
